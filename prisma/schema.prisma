generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum PartType {
  TEXT
  VIDEO
  DOWNLOAD
  QUIZ
  SUBMIT
}

enum HourCategory {
  OBSERVATION
  TEACHING
  SELF_PRACTICE
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  role                Role                 @default(USER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  progress            Progress[]
  questions           Question[]
  quizAttempts        QuizAttempt[]
  submissions         Submission[]
  hourLogs            HourLog[]            @relation("HourLogStudent")
  signedOffLogs       HourLog[]            @relation("HourLogSigner")
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Application {
  id         String   @id @default(cuid())
  name       String
  email      String
  pathway    String // "A" | "B" | "C" — free-text so we can add pathways without a migration
  notes      String?  @db.Text
  contacted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

/// One row per editable landing-page section. `template` picks the
/// React layout variant; `content` is a JSON blob whose shape depends
/// on the section (typed in code).
model LandingSection {
  id        String   @id @default(cuid())
  section   String   @unique // "hero" | "tutors" | "gallery" | "pathways"
  template  String   // layout variant id, e.g. "full-bleed" / "split-screen"
  content   Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

/// One row per uploaded image slot. Slot id is well-known
/// ("hero-bg", "tutor-kelly", etc.) — admin only uploads/overwrites.
model LandingAsset {
  id        String   @id @default(cuid())
  slot      String   @unique
  imagePath String // storage path inside the "landing/" bucket folder
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Section {
  id                      String     @id @default(cuid())
  title                   String
  slug                    String     @unique
  description             String
  content                 String     @db.Text
  order                   Int        @unique
  unlockDate              DateTime
  requiresPriorCompletion Boolean    @default(true)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  progress                Progress[]
  questions               Question[]
  parts                   Part[]
  hourLogs                HourLog[]
}

model Part {
  id          String       @id @default(cuid())
  sectionId   String
  order       Int
  title       String
  type        PartType
  body        String?      @db.Text
  videoUrl    String?
  fileUrl     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  section     Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  quiz        Quiz?
  submissions Submission[]

  @@unique([sectionId, order])
}

model Quiz {
  id           String         @id @default(cuid())
  partId       String         @unique
  passingScore Int            @default(70)
  maxAttempts  Int? // null = unlimited
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  part         Part           @relation(fields: [partId], references: [id], onDelete: Cascade)
  questions    QuizQuestion[]
  attempts     QuizAttempt[]
}

model QuizQuestion {
  id      String       @id @default(cuid())
  quizId  String
  prompt  String       @db.Text
  order   Int
  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  choices QuizChoice[]

  @@unique([quizId, order])
}

model QuizChoice {
  id         String       @id @default(cuid())
  questionId String
  text       String       @db.Text
  isCorrect  Boolean      @default(false)
  order      Int
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, order])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int
  passed      Boolean
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Submission {
  id          String    @id @default(cuid())
  userId      String
  partId      String
  content     String    @db.Text
  fileUrl     String?
  feedback    String?   @db.Text
  submittedAt DateTime  @default(now())
  reviewed    Boolean   @default(false)
  reviewedAt  DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  part        Part      @relation(fields: [partId], references: [id], onDelete: Cascade)
}

model Progress {
  id          String    @id @default(cuid())
  userId      String
  sectionId   String
  completed   Boolean   @default(false)
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
}

model Question {
  id          String    @id @default(cuid())
  userId      String
  sectionId   String
  message     String    @db.Text
  response    String?   @db.Text
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model HourLog {
  id              String       @id @default(cuid())
  userId          String
  sectionId       String?
  category        HourCategory
  date            DateTime
  durationMinutes Int
  description     String       @db.Text
  fileUrl         String?
  signedOffById   String?
  signedOffAt     DateTime?
  feedback        String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation("HourLogStudent", fields: [userId], references: [id], onDelete: Cascade)
  signedOffBy     User?        @relation("HourLogSigner", fields: [signedOffById], references: [id], onDelete: SetNull)
  section         Section?     @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([signedOffById])
}
